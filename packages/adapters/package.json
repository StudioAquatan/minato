{
  "name": "@minato/adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/postgres/index.ts",
    "./search": "./src/search/index.ts",
    "./llm": "./src/llm/index.ts",
    "./parser": "./src/parser/index.ts",
    "./storage": "./src/storage/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/postgres/migrate.ts"
  },
  "dependencies": {
    "@minato/core": "workspace:*",
    "@minato/contracts": "workspace:*",
    "@opendataloader/pdf": "^2.5.0",
    "drizzle-orm": "^0.38.3",
    "fast-xml-parser": "^4.5.1",
    "meilisearch": "^0.59.0",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
