# PostgreSQL
POSTGRES_USER=minato
POSTGRES_PASSWORD=minato
POSTGRES_DB=minato
POSTGRES_PORT=5432
DATABASE_URL=postgres://minato:minato@localhost:5432/minato

# Meilisearch
MEILI_ENV=development
MEILI_MASTER_KEY=masterKeyMasterKeyMasterKey
MEILI_PORT=7700
MEILI_URL=http://localhost:7700

# Ollama (embeddings)
OLLAMA_PORT=11434
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3

# GROBID (bibliographic + reference extraction)
GROBID_IMAGE=lfoppiano/grobid:0.8.2
GROBID_PORT=8070
GROBID_URL=http://localhost:8070
GROBID_CONCURRENCY=4
GROBID_REQUEST_TIMEOUT_MS=300000
GROBID_MAX_RETRIES=3
GROBID_JAVA_OPTS=-Xmx4g

# Storage (PDF originals live here)
STORAGE_ROOT=./data/pdf

# Worker
WORKER_ID=worker-local
WORKER_HEARTBEAT_MS=5000
WORKER_POLL_MS=1000
WORKER_LANES=default,parse,index,embed
